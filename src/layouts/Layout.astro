---
import '../styles/global.css';
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Airbnb Split & Payments - La Polla</title>
		<!-- Google Fonts: Outfit -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0b130e] text-slate-100 font-sans min-h-screen selection:bg-emerald-500 selection:text-emerald-950 overflow-x-hidden antialiased">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
	}
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background-color: #080f0b;
	}
	/* Custom scrollbar to match Material Design 3 and Emerald theme */
	::-webkit-scrollbar {
		width: 8px;
		height: 8px;
	}
	::-webkit-scrollbar-track {
		background: #080f0b;
	}
	::-webkit-scrollbar-thumb {
		background: #1e3a2b;
		border-radius: 9999px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: #10b981;
	}
</style>

