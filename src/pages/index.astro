---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<!-- Script para confetti -->
	<script is:inline src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>

	<main class="min-h-screen pb-20 sm:pb-24 relative">
		<!-- Fondo animado -->
		<div class="bg-animation" aria-hidden="true">
			<div class="bg-orb bg-orb-1"></div>
			<div class="bg-orb bg-orb-2"></div>
			<div class="bg-orb bg-orb-3"></div>
			<div class="bg-orb bg-orb-4"></div>
			<div class="bg-shimmer"></div>
		</div>
		<!-- Cabecera Principal -->
		<header class="max-w-6xl mx-auto pt-6 sm:pt-8 px-4 text-center safe-top">
			<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-950/50 border border-emerald-800/30 text-emerald-400 text-xs font-semibold mb-4 tracking-wider uppercase">
				🏝️ Airbnb Splitter MXN
			</div>
			<h1 class="text-2xl sm:text-5xl font-bold tracking-tight text-white mb-2">
				La Renta del <span class="text-emerald-400 bg-clip-text">Airbnb</span>
			</h1>
			<p class="text-slate-400 text-sm sm:text-base max-w-md mx-auto">
				Control de pagos para los viajeros. ¡Fácil, rápido y en tiempo real!
			</p>
		</header>

		<!-- Pestañas de Navegación Estilo Material Design 3 -->
		<nav class="max-w-md mx-auto my-5 sm:my-8 px-4">
			<div class="bg-slate-950/80 p-1 rounded-full flex gap-1 border border-emerald-950/40 backdrop-blur-lg shadow-inner">
				<button data-tab="resumen" class="tab-btn active w-full text-center py-3 sm:py-2.5 text-sm font-semibold rounded-full transition-all duration-300 flex items-center justify-center gap-1.5 cursor-pointer min-h-[44px]">
					📊 Resumen
				</button>
				<button data-tab="tabla" class="tab-btn w-full text-center py-3 sm:py-2.5 text-sm font-semibold rounded-full transition-all duration-300 flex items-center justify-center gap-1.5 cursor-pointer min-h-[44px]">
					👥 Lista
				</button>
			</div>
		</nav>

		<!-- Contenido de las Pestañas -->
		<section class="max-w-6xl mx-auto px-4">
			
			<!-- TAB 1: RESUMEN / DASHBOARD -->
			<div id="tab-resumen" class="tab-content transition-all duration-500 ease-out space-y-6">
				<!-- Tarjetas de Métricas Rápidas -->
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
					<!-- Renta Total -->
					<div class="bg-slate-900/60 p-4 sm:p-6 rounded-[20px] sm:rounded-[28px] border border-white/5 backdrop-blur-md flex flex-col justify-between shadow-xl">
						<span class="text-xs font-medium text-slate-400 flex items-center gap-1.5">
							💰 Renta Total
						</span>
						<div class="mt-2">
							<span id="metric-total-cost" class="text-2xl sm:text-3xl font-bold text-white">$6,400.00</span>
							<span class="text-xs font-semibold text-slate-500 ml-1">MXN</span>
						</div>
						<div class="text-[11px] text-emerald-400/80 mt-2">
							$400 por persona · $800 con acompañante
						</div>
					</div>

					<!-- Cuota por Persona -->
					<div class="bg-slate-900/60 p-4 sm:p-6 rounded-[20px] sm:rounded-[28px] border border-white/5 backdrop-blur-md flex flex-col justify-between shadow-xl">
						<span class="text-xs font-medium text-slate-400">
							👥 Cuota Individual
						</span>
						<div class="mt-2">
							<span id="metric-split-cost" class="text-2xl sm:text-3xl font-bold text-emerald-400">$400.00</span>
							<span class="text-xs font-semibold text-slate-500 ml-1">MXN</span>
						</div>
						<div class="text-[11px] text-slate-400 mt-2">
							Solo / <span class="font-bold text-slate-300">$800</span> con acompañante
						</div>
					</div>

					<!-- Estado de Recaudación -->
					<div class="bg-slate-900/60 p-4 sm:p-6 rounded-[20px] sm:rounded-[28px] border border-white/5 backdrop-blur-md flex flex-col justify-between shadow-xl">
						<span class="text-xs font-medium text-slate-400">
							📈 Recaudado por Depositar
						</span>
						<div class="mt-2">
							<span id="metric-collected" class="text-2xl sm:text-3xl font-bold text-white">$0.00</span>
							<span class="text-xs font-semibold text-slate-500 ml-1">MXN</span>
						</div>
						<div class="text-[11px] text-slate-400 mt-2 flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
							<span>Restan: <strong id="metric-remaining" class="text-emerald-400">$8,888.89</strong></span>
							<span id="metric-people-paid-count" class="font-bold text-slate-300">1 de 9 pagados</span>
						</div>
					</div>
				</div>

				<!-- Panel Gráfico de Progreso -->
				<div class="grid grid-cols-1 md:grid-cols-5 gap-4 sm:gap-6">
					<!-- Gráfico circular SVG -->
					<div class="md:col-span-2 bg-slate-900/60 p-5 sm:p-8 rounded-[20px] sm:rounded-[28px] border border-white/5 backdrop-blur-md flex flex-col items-center justify-center text-center shadow-xl relative min-h-[240px] sm:min-h-[300px]">
						<div class="relative w-36 h-36 sm:w-48 sm:h-48 flex items-center justify-center">
							<!-- Círculo de Fondo -->
							<svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
								<circle cx="50" cy="50" r="40" stroke="#14281f" stroke-width="10" fill="transparent" />
								<!-- Círculo de Progreso -->
								<circle id="progress-circle" cx="50" cy="50" r="40" stroke="#10b981" stroke-width="10" fill="transparent"
										stroke-dasharray="251.2" stroke-dashoffset="251.2" stroke-linecap="round"
										class="transition-all duration-1000 ease-out" />
							</svg>
							<!-- Texto Central -->
							<div class="absolute flex flex-col items-center">
								<span id="progress-percent" class="text-3xl sm:text-4xl font-bold text-white">0%</span>
								<span class="text-[10px] text-slate-400 uppercase tracking-wider font-semibold mt-1">Recaudado</span>
							</div>
						</div>
						<div class="mt-4">
							<h3 class="text-slate-300 text-sm font-semibold">Progreso de la Renta</h3>
							<p class="text-xs text-slate-500 mt-1 max-w-[200px]">El objetivo es liquidar la parte correspondiente a los 8 depositantes.</p>
						</div>
					</div>

					<!-- Visualización de Estatus Rápido por Persona -->
					<div class="md:col-span-3 bg-slate-900/60 p-4 sm:p-6 rounded-[20px] sm:rounded-[28px] border border-white/5 backdrop-blur-md flex flex-col justify-between shadow-xl">
						<div>
							<h3 class="text-sm font-bold text-slate-200 mb-3 sm:mb-4 flex items-center gap-1.5">
								📌 Estatus del Grupo
							</h3>
							<div id="grid-mini-status" class="grid grid-cols-2 sm:grid-cols-3 gap-2 sm:gap-2">
								<!-- Cargado dinámicamente -->
							</div>
						</div>

						<div class="border-t border-emerald-950/40 pt-4 mt-6">
							<div class="flex flex-col sm:flex-row justify-between items-center gap-3">
								<div class="text-xs text-slate-400">
									🚀 Comparte este enlace con tu grupo para coordinar los pagos.
								</div>
								<button id="btn-share-dash" class="w-full sm:w-auto text-xs px-4 py-3 sm:py-2 bg-emerald-950/80 hover:bg-emerald-900 border border-emerald-500/20 text-emerald-300 rounded-full font-medium active:scale-95 transition-all flex items-center justify-center gap-1.5 cursor-pointer min-h-[44px]">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" />
									</svg>
									<span>Compartir Enlace</span>
								</button>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- TAB 2: TABLA DE PAGOS -->
			<div id="tab-tabla" class="tab-content hidden transition-all duration-500 ease-out space-y-4">
				<div class="bg-slate-900/60 rounded-[20px] sm:rounded-[28px] border border-white/5 backdrop-blur-md shadow-xl overflow-hidden">
					<div class="p-4 sm:p-6 border-b border-emerald-950/40 flex justify-between items-center flex-wrap gap-2">
						<div>
							<h2 class="text-base sm:text-lg font-bold text-white">Detalle de Aportaciones</h2>
							<p class="text-xs text-slate-400 mt-0.5">Vista general del grupo de viajeros.</p>
						</div>
					</div>

					<!-- Vista móvil: tarjetas -->
					<div id="mobile-list" class="md:hidden p-3 sm:p-4 space-y-3">
						<!-- Se llena dinámicamente -->
					</div>

					<!-- Vista escritorio: tabla -->
					<div class="hidden md:block overflow-x-auto">
						<table class="w-full text-left text-sm border-collapse">
							<thead>
								<tr class="text-[11px] uppercase tracking-wider text-slate-500 border-b border-emerald-950/20 bg-slate-950/40">
									<th class="py-3.5 px-6">Nombre</th>
									<th class="py-3.5 px-6 text-center">Integrantes</th>
									<th class="py-3.5 px-6 text-right">Cuota Esperada</th>
									<th class="py-3.5 px-6 text-center">Abonado</th>
									<th class="py-3.5 px-6 text-right">Faltante</th>
									<th class="py-3.5 px-6 text-center">Estado</th>
								</tr>
							</thead>
							<tbody id="table-body" class="divide-y divide-emerald-950/20">
								<!-- Se llena dinámicamente -->
							</tbody>
						</table>
					</div>
				</div>
			</div>

		<!-- Toast Notification (Material Notification) -->
		<div id="toast" class="fixed bottom-6 sm:bottom-24 left-4 right-4 sm:left-1/2 sm:right-auto sm:-translate-x-1/2 sm:max-w-md bg-slate-900/90 border border-emerald-500/30 pl-5 pr-4 py-3 rounded-2xl sm:rounded-full text-slate-100 text-sm shadow-2xl flex items-center gap-2.5 opacity-0 pointer-events-none translate-y-4 transition-all duration-300 z-50 backdrop-blur-md safe-bottom">
			<span id="toast-icon" class="text-lg">✅</span>
			<span id="toast-text" class="font-semibold text-slate-200">Enlace copiado al portapapeles</span>
			<button id="btn-close-toast" class="ml-2 text-slate-400 hover:text-white transition-colors cursor-pointer p-0.5 rounded-full hover:bg-white/10" title="Cerrar aviso">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
					<path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
				</svg>
			</button>
		</div>

		<!-- MODAL DE CELEBRACIÓN (META ALCANZADA) -->
		<div id="celebration-modal" class="fixed inset-0 bg-slate-950/80 backdrop-blur-md z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-all duration-500">
			<div class="bg-gradient-to-br from-[#0e2a1b] to-[#08120c] p-6 sm:p-8 rounded-[28px] sm:rounded-[36px] border border-emerald-400/30 max-w-sm w-full text-center relative shadow-2xl scale-95 transition-all duration-500 mx-auto" id="celebration-card">
				<!-- Efecto de luz de fondo -->
				<div class="absolute -top-12 -left-12 w-24 h-24 bg-emerald-500/20 rounded-full blur-2xl pointer-events-none"></div>
				<div class="absolute -bottom-12 -right-12 w-24 h-24 bg-emerald-400/20 rounded-full blur-2xl pointer-events-none"></div>

				<div class="w-20 h-20 bg-emerald-500/20 rounded-full mx-auto flex items-center justify-center text-4xl border border-emerald-400/30 animate-bounce">
					🎉
				</div>
				<h2 class="text-2xl font-bold text-white mt-6">¡Meta Cumplida!</h2>
				<p class="text-emerald-400 font-semibold text-sm mt-1">¡Renta Airbnb 100% pagada!</p>
				<p class="text-slate-300 text-xs mt-3 leading-relaxed">
					Todos los integrantes han depositado su parte. La cuenta total de la renta está liquidada.
				</p>
				
				<div class="mt-6 flex flex-col gap-2">
					<button id="btn-more-confetti" class="w-full bg-emerald-500 hover:bg-emerald-400 text-emerald-950 font-bold py-3 rounded-full text-xs uppercase tracking-wider transition-all cursor-pointer">
						💥 ¡Más Confeti!
					</button>
					<button id="btn-close-celebration" class="w-full bg-slate-950/50 hover:bg-slate-950 border border-white/5 text-slate-400 hover:text-white py-2.5 rounded-full text-xs transition-all cursor-pointer">
						Cerrar
					</button>
				</div>
			</div>
		</div>

	</main>

	<!-- Estilos para pestañas y animaciones -->
	<style>
		.bg-animation {
			position: fixed;
			inset: 0;
			z-index: -10;
			overflow: hidden;
			pointer-events: none;
			background: #080f0b;
		}

		.bg-orb {
			position: absolute;
			border-radius: 50%;
			filter: blur(100px);
			will-change: transform;
		}

		.bg-orb-1 {
			top: -10%;
			left: 15%;
			width: 28rem;
			height: 28rem;
			background: rgba(16, 185, 129, 0.14);
			animation: orb-drift-1 22s ease-in-out infinite;
		}

		.bg-orb-2 {
			bottom: 5%;
			right: 10%;
			width: 32rem;
			height: 32rem;
			background: rgba(5, 150, 105, 0.1);
			animation: orb-drift-2 26s ease-in-out infinite;
		}

		.bg-orb-3 {
			top: 40%;
			right: -5%;
			width: 20rem;
			height: 20rem;
			background: rgba(52, 211, 153, 0.08);
			animation: orb-drift-3 18s ease-in-out infinite;
		}

		.bg-orb-4 {
			bottom: 30%;
			left: -8%;
			width: 24rem;
			height: 24rem;
			background: rgba(6, 95, 70, 0.12);
			animation: orb-drift-4 24s ease-in-out infinite;
		}

		.bg-shimmer {
			position: absolute;
			inset: 0;
			background: linear-gradient(
				125deg,
				transparent 0%,
				rgba(16, 185, 129, 0.03) 25%,
				transparent 50%,
				rgba(5, 150, 105, 0.04) 75%,
				transparent 100%
			);
			background-size: 200% 200%;
			animation: shimmer-sweep 12s ease-in-out infinite;
		}

		@keyframes orb-drift-1 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			33% { transform: translate(40px, 60px) scale(1.08); }
			66% { transform: translate(-30px, 20px) scale(0.95); }
		}

		@keyframes orb-drift-2 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			40% { transform: translate(-50px, -40px) scale(1.1); }
			70% { transform: translate(30px, -20px) scale(0.92); }
		}

		@keyframes orb-drift-3 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			50% { transform: translate(-60px, 50px) scale(1.05); }
		}

		@keyframes orb-drift-4 {
			0%, 100% { transform: translate(0, 0) scale(1); }
			45% { transform: translate(50px, -30px) scale(1.12); }
			80% { transform: translate(-20px, 40px) scale(0.9); }
		}

		@keyframes shimmer-sweep {
			0%, 100% { background-position: 0% 50%; }
			50% { background-position: 100% 50%; }
		}

		@media (prefers-reduced-motion: reduce) {
			.bg-orb,
			.bg-shimmer {
				animation: none;
			}
		}

		@media (max-width: 640px) {
			.bg-orb-1 { width: 18rem; height: 18rem; }
			.bg-orb-2 { width: 20rem; height: 20rem; }
			.bg-orb-3 { width: 14rem; height: 14rem; }
			.bg-orb-4 { width: 16rem; height: 16rem; }
			.bg-orb { filter: blur(70px); }
		}

		.safe-top {
			padding-top: max(1.5rem, env(safe-area-inset-top));
		}

		.safe-bottom {
			margin-bottom: env(safe-area-inset-bottom);
		}

		.mini-status-card {
			min-height: 4.5rem;
			padding: 0.625rem 0.5rem;
		}

		@media (min-width: 640px) {
			.mini-status-card {
				min-height: auto;
				padding: 0.75rem;
			}
		}

		.tab-btn {
			background-color: transparent;
			color: #94a3b8; /* slate-400 */
		}
		.tab-btn.active {
			background-color: #047857; /* emerald-700 */
			color: #ffffff;
			box-shadow: 0 4px 12px rgba(4, 120, 87, 0.25);
		}
	</style>

	<!-- Script de Lógica Principal -->
	<script>
		// Estado inicial por defecto
		// shares: cuántas personas (1 = solo, 2 = con acompañante)
		// cuota fija: $400 por persona
		const CUOTA_POR_PERSONA = 400;

		const defaultState = {
			rentTotal: 6400,
			people: [
				{ name: "Charli y su novia", shares: 2, paidAmount: 400 },
				{ name: "Mario y su novia", shares: 2, paidAmount: 400 },
				{ name: "Bruno y su novia", shares: 2, paidAmount: 400 },
				{ name: "Luis y su novia", shares: 2, paidAmount: 400 },
				{ name: "Vic y su esposa", shares: 2, paidAmount: 800 },
				{ name: "Grego y su novia", shares: 2, paidAmount: 400 },
				{ name: "Angel", shares: 1, paidAmount: 300 },
				{ name: "Cucho", shares: 1, paidAmount: 300 },
				{ name: "Abel", shares: 1, paidAmount: 50 },
				{ name: "Iván", shares: 1, paidAmount: 0 }
			]
		};

		// Estado actual de la aplicación (solo lectura)
		const state = { ...defaultState };

		// Elementos del DOM
		const tabButtons = document.querySelectorAll('nav button[data-tab]');
		const tabContents = document.querySelectorAll('.tab-content');

		// Métricas del Dashboard
		const metricTotalCost = document.getElementById('metric-total-cost');
		const metricSplitCost = document.getElementById('metric-split-cost');
		const metricCollected = document.getElementById('metric-collected');
		const metricRemaining = document.getElementById('metric-remaining');
		const metricPeoplePaidCount = document.getElementById('metric-people-paid-count');

		// SVG Dona Gráfica
		const progressCircle = document.getElementById('progress-circle');
		const progressPercent = document.getElementById('progress-percent');
		const gridMiniStatus = document.getElementById('grid-mini-status');

		// Tabla de pagos
		const tableBody = document.getElementById('table-body');
		const mobileList = document.getElementById('mobile-list');

		// Notificaciones Toast y Modal Celebración
		const toast = document.getElementById('toast');
		const toastText = document.getElementById('toast-text');
		const toastIcon = document.getElementById('toast-icon');
		const btnCloseToast = document.getElementById('btn-close-toast');

		const celebrationModal = document.getElementById('celebration-modal');
		const celebrationCard = document.getElementById('celebration-card');
		const btnMoreConfetti = document.getElementById('btn-more-confetti');
		const btnCloseCelebration = document.getElementById('btn-close-celebration');

		// Carga inicial al cargar el script
		init();

		function init() {
			setupEventListeners();
			render();
		}

		// Configurar los listeners de eventos
		function setupEventListeners() {
			// Cambios de pestaña
			tabButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					const tabId = btn.getAttribute('data-tab');
					switchTab(tabId);
				});
			});

			// Cerrar avisos manualmente
			if (btnCloseToast) {
				btnCloseToast.addEventListener('click', hideToast);
			}

			// Celebración
			btnMoreConfetti.addEventListener('click', triggerGreenConfetti);
			btnCloseCelebration.addEventListener('click', closeCelebrationModal);
			celebrationModal.addEventListener('click', (e) => {
				if (e.target === celebrationModal) {
					closeCelebrationModal();
				}
			});
		}

		// Cambiar de pestaña con animaciones
		function switchTab(tabId) {
			tabButtons.forEach(btn => {
				if (btn.getAttribute('data-tab') === tabId) {
					btn.classList.add('active');
				} else {
					btn.classList.remove('active');
				}
			});

			tabContents.forEach(content => {
				if (content.id === `tab-${tabId}`) {
					content.classList.remove('hidden');
					content.style.opacity = '0';
					content.style.transform = 'translateY(10px)';
					setTimeout(() => {
						content.style.opacity = '1';
						content.style.transform = 'translateY(0)';
					}, 50);
				} else {
					content.classList.add('hidden');
				}
			});
		}

		// Renderizar todos los elementos de la UI a partir del estado
		function render() {
			// 1. Cálculos de Dinero
			const totalCost = state.rentTotal;
			const splitCost = CUOTA_POR_PERSONA;
			
			// Calcular cuánto se ha recaudado en total y cuántos están al corriente
			let totalCollected = 0;
			let fullyPaidCount = 0;
			
			state.people.forEach(p => {
				const expectedForPerson = (p.shares || 1) * splitCost;
				totalCollected += (p.paidAmount || 0);
				if ((p.paidAmount || 0) >= expectedForPerson) {
					fullyPaidCount++;
				}
			});

			const remainingToCollect = Math.max(0, totalCost - totalCollected);
			const progressPercentage = totalCost > 0 ? Math.min(100, Math.round((totalCollected / totalCost) * 100)) : 100;

			// 2. Pintar en Métricas
			metricTotalCost.innerText = formatCurrency(totalCost);
			metricSplitCost.innerText = formatCurrency(splitCost);
			metricCollected.innerText = formatCurrency(totalCollected);
			metricRemaining.innerText = formatCurrency(remainingToCollect);
			metricPeoplePaidCount.innerText = `${fullyPaidCount} de ${state.people.length} al corriente`;

			// 3. Pintar Gráfico Circular SVG
			const strokeDashoffset = 251.2 - (251.2 * progressPercentage) / 100;
			progressCircle.setAttribute('stroke-dashoffset', strokeDashoffset.toString());
			progressPercent.innerText = `${progressPercentage}%`;

			// 4. Renderizar Rejilla de Estatus Rápido (Dashboard)
			gridMiniStatus.innerHTML = '';
			state.people.forEach((p) => {
				const expectedAmount = (p.shares || 1) * splitCost;
				const pendingAmount = Math.max(0, expectedAmount - (p.paidAmount || 0));
				
				const statusColor = pendingAmount <= 0 
					? 'bg-emerald-950/60 text-emerald-400 border-emerald-900/40' 
					: (p.paidAmount > 0 
						? 'bg-amber-950/50 text-amber-400 border-amber-900/30' 
						: 'bg-slate-950/80 text-slate-500 border-slate-900');
				
				const badge = pendingAmount <= 0 
					? '✅ Pagado' 
					: `Faltan ${formatCurrency(pendingAmount)}`;

				const div = document.createElement('div');
				div.className = `mini-status-card rounded-2xl border ${statusColor} text-center flex flex-col items-center justify-center gap-0.5 sm:gap-1 transition-all duration-300 shadow-md`;
				div.innerHTML = `
					<span class="text-[11px] sm:text-xs font-bold leading-tight line-clamp-2 text-white px-0.5">${p.name}</span>
					<span class="text-[9px] sm:text-[9px] font-semibold uppercase tracking-wide leading-tight">${badge}</span>
				`;
				gridMiniStatus.appendChild(div);
			});

			// 5. Renderizar Tabla de Pagos (escritorio) y tarjetas (móvil)
			tableBody.innerHTML = '';
			if (mobileList) mobileList.innerHTML = '';

			state.people.forEach((p) => {
				const expectedAmount = (p.shares || 1) * splitCost;
				const pendingAmount = Math.max(0, expectedAmount - (p.paidAmount || 0));
				const sharesLabel = `${p.shares || 1} ${p.shares > 1 ? 'personas' : 'persona'}`;

				let statusBadge = '';
				if (pendingAmount <= 0) {
					statusBadge = `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-emerald-950 text-emerald-400 border border-emerald-800/40">✔️ Completo</span>`;
				} else {
					statusBadge = `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-amber-950 text-amber-400 border border-amber-800/30">Faltan ${formatCurrency(pendingAmount)}</span>`;
				}

				const pendingText = pendingAmount > 0 
					? `<span class="text-amber-500 font-bold">Faltan ${formatCurrency(pendingAmount)}</span>`
					: `<span class="text-slate-500 font-medium">$0.00</span>`;

				// Tarjeta móvil
				if (mobileList) {
					const cardBorder = pendingAmount <= 0
						? 'border-emerald-900/40'
						: (p.paidAmount > 0 ? 'border-amber-900/30' : 'border-slate-800');
					const card = document.createElement('article');
					card.className = `rounded-2xl border ${cardBorder} bg-slate-950/50 p-4 space-y-3`;
					card.innerHTML = `
						<div class="flex items-start gap-3">
							<div class="w-10 h-10 shrink-0 rounded-full bg-emerald-950/80 border border-emerald-500/30 flex items-center justify-center text-emerald-400 font-bold text-sm uppercase">
								${p.name.charAt(0)}
							</div>
							<div class="min-w-0 flex-1">
								<p class="text-sm font-bold text-white leading-snug">${p.name}</p>
								<p class="text-xs text-slate-400 mt-0.5">${sharesLabel}</p>
							</div>
							<div class="shrink-0">${statusBadge}</div>
						</div>
						<div class="grid grid-cols-3 gap-2 text-center">
							<div class="rounded-xl bg-slate-900/60 py-2 px-1">
								<p class="text-[10px] text-slate-500 uppercase tracking-wide">Esperada</p>
								<p class="text-xs font-semibold text-slate-200 mt-0.5">${formatCurrency(expectedAmount)}</p>
							</div>
							<div class="rounded-xl bg-slate-900/60 py-2 px-1">
								<p class="text-[10px] text-slate-500 uppercase tracking-wide">Abonado</p>
								<p class="text-xs font-bold text-emerald-400 mt-0.5">${formatCurrency(p.paidAmount || 0)}</p>
							</div>
							<div class="rounded-xl bg-slate-900/60 py-2 px-1">
								<p class="text-[10px] text-slate-500 uppercase tracking-wide">Faltante</p>
								<p class="text-xs font-bold mt-0.5 ${pendingAmount > 0 ? 'text-amber-500' : 'text-slate-500'}">${pendingAmount > 0 ? `Faltan ${formatCurrency(pendingAmount)}` : '$0.00'}</p>
							</div>
						</div>
					`;
					mobileList.appendChild(card);
				}
				
				const tr = document.createElement('tr');
				tr.className = `hover:bg-emerald-950/15 transition-colors`;
				
				const nameCol = `
					<td class="py-4 px-6 font-semibold text-white">
						<div class="flex items-center gap-2">
							<div class="w-8 h-8 rounded-full bg-emerald-950/80 border border-emerald-500/30 flex items-center justify-center text-emerald-400 font-bold text-xs uppercase shadow-inner shrink-0">
								${p.name.charAt(0)}
							</div>
							<span class="text-sm font-semibold">${p.name}</span>
						</div>
					</td>
				`;
				const sharesCol = `<td class="py-4 px-6 text-center text-slate-300 font-medium">${sharesLabel}</td>`;
				const expectedCol = `<td class="py-4 px-6 text-right text-slate-200 font-medium">${formatCurrency(expectedAmount)}</td>`;
				const paidCol = `<td class="py-4 px-6 text-center text-emerald-400 font-bold">${formatCurrency(p.paidAmount || 0)}</td>`;
				const pendingCol = `<td class="py-4 px-6 text-right">${pendingText}</td>`;
				const statusCol = `<td class="py-4 px-6 text-center">${statusBadge}</td>`;

				tr.innerHTML = nameCol + sharesCol + expectedCol + paidCol + pendingCol + statusCol;
				tableBody.appendChild(tr);
			});

			// 6. Lanzar animación si alcanzamos 100% de la meta
			checkGoalCelebration(fullyPaidCount, state.people.length);
		}

		// Monitorear si llegamos al 100%
		let wasCelebrated = false;
		function checkGoalCelebration(paidCount, totalCount) {
			if (paidCount === totalCount && totalCount > 0) {
				const sessionCelebrated = sessionStorage.getItem('airbnb_goal_celebrated') === 'true';
				if (!wasCelebrated && !sessionCelebrated) {
					triggerGreenConfetti();
					openCelebrationModal();
					sessionStorage.setItem('airbnb_goal_celebrated', 'true');
					wasCelebrated = true;
				}
			} else {
				sessionStorage.removeItem('airbnb_goal_celebrated');
				wasCelebrated = false;
			}
		}

		// Lanzar confeti
		function triggerGreenConfetti() {
			if (typeof confetti === 'function') {
				const duration = 3 * 1000;
				const end = Date.now() + duration;
				const colors = ['#10b981', '#34d399', '#059669', '#a7f3d0', '#fbbf24', '#f59e0b'];

				(function frame() {
					confetti({ particleCount: 3, angle: 60, spread: 55, origin: { x: 0 }, colors: colors });
					confetti({ particleCount: 3, angle: 120, spread: 55, origin: { x: 1 }, colors: colors });
					if (Date.now() < end) {
						requestAnimationFrame(frame);
					}
				}());
			}
		}

		function openCelebrationModal() {
			celebrationModal.classList.remove('opacity-0', 'pointer-events-none');
			celebrationCard.classList.remove('scale-95');
			celebrationCard.classList.add('scale-100');
		}

		function closeCelebrationModal() {
			celebrationModal.classList.add('opacity-0', 'pointer-events-none');
			celebrationCard.classList.remove('scale-100');
			celebrationCard.classList.add('scale-95');
		}

		function hideToast() {
			toast.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
			toast.classList.remove('opacity-100', 'translate-y-0');
		}

		function formatCurrency(value) {
			return new Intl.NumberFormat('es-MX', {
				style: 'currency',
				currency: 'MXN'
			}).format(value);
		}
	</script>
</Layout>
